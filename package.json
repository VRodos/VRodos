{
  "name": "vrodos-plugin",
  "version": "2.5.0",
  "description": "VRodos WordPress Plugin",
  "vrodos": {
    "runtime": {
      "aframe": {
        "label": "A-Frame master",
        "source": "cdn-master",
        "version": "1.7.1",
        "commit": "96cc74fa7a4640f394a78985a637a788daf56186",
        "url": "https://cdn.jsdelivr.net/gh/aframevr/aframe@96cc74fa7a4640f394a78985a637a788daf56186/dist/aframe-master.min.js"
      }
    }
  },
  "scripts": {
    "build": "npm run build:three && npm run build:css",
    "build:three": "node ./scripts/build-three-vendor.mjs",
    "build:vendor": "npm run build:three",
    "lint": "eslint \"assets/js/runtime/master/**/*.js\"",
    "lint:fix": "eslint \"assets/js/runtime/master/**/*.js\" --fix",
    "format": "prettier --write \"**/*.{js,css,md,json}\"",
    "build:css": "tailwindcss -i ./assets/css/vrodos_modern.css -o ./assets/css/vrodos_modern_compiled.css",
    "watch:css": "tailwindcss -i ./assets/css/vrodos_modern.css -o ./assets/css/vrodos_modern_compiled.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "daisyui": "^4.12.24",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "n8ao": "^1.10.1",
    "postcss": "^8.5.12",
    "postprocessing": "^6.39.1",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "three": "^0.181.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "dependencies": {
    "@takram/three-atmosphere": "^0.18.0",
    "@takram/three-clouds": "^0.7.4"
  }
}
