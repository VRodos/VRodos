{
  "name": "vrodos-plugin",
  "version": "2.5.0",
  "description": "VRodos WordPress Plugin",
  "vrodos": {
    "runtime": {
      "aframe": {
        "label": "A-Frame master",
        "source": "cdn-master",
        "version": "1.7.1",
        "commit": "adf8f4e02b0499223b2c4fa93165e49b50384564",
        "url": "https://cdn.jsdelivr.net/gh/aframevr/aframe@adf8f4e02b0499223b2c4fa93165e49b50384564/dist/aframe-master.min.js"
      }
    }
  },
  "scripts": {
    "build": "npm run build:three && npm run build:runtime && npm run build:css",
    "build:all": "npm run build:naf && npm run build",
    "build:three": "node ./scripts/build-three-vendor.mjs",
    "build:runtime": "node ./scripts/build-runtime-master-bundles.mjs",
    "build:naf": "node ./scripts/build-networked-aframe-vendor.mjs",
    "build:vendor": "npm run build:three",
    "assets:audit:master": "node ./scripts/audit-master-client-assets.mjs",
    "assets:optimize:prototype": "node ./scripts/prototype-optimize-master-client-assets.mjs",
    "lint": "eslint \"assets/js/{editor,runtime}/**/*.js\"",
    "lint:fix": "eslint \"assets/js/{editor,runtime}/**/*.js\" --fix",
    "test:runtime": "node ./scripts/test-navigation-math.mjs && node ./scripts/test-assessment-runtime.mjs && node ./scripts/test-xr-exit-handoff.mjs",
    "test:compiler": "node ./scripts/run-compiler-runtime-tests.mjs",
    "format": "prettier --write \"**/*.{js,css,md,json}\"",
    "build:css": "tailwindcss -i ./assets/css/vrodos_modern.css -o ./assets/css/vrodos_modern_compiled.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/vrodos_modern.css -o ./assets/css/vrodos_modern_compiled.css --watch --minify",
    "watch:css:dev": "tailwindcss -i ./assets/css/vrodos_modern.css -o ./assets/css/vrodos_modern_compiled.css --watch",
    "size:css": "node ./scripts/report-css-size.mjs"
  },
  "devDependencies": {
    "@gltf-transform/cli": "4.4.0",
    "autoprefixer": "^10.5.2",
    "daisyui": "^4.12.24",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "meshoptimizer": "^1.1.1",
    "postcss": "^8.5.16",
    "postprocessing": "^6.39.2",
    "prettier": "^3.9.4",
    "tailwindcss": "^3.4.19",
    "three": "npm:super-three@0.184.0",
    "three-mesh-bvh": "^0.9.10"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@pmndrs/pointer-events": "^6.6.30",
    "@pmndrs/uikit": "^1.0.74",
    "@pmndrs/uikit-horizon": "^1.0.74",
    "@pmndrs/uikit-lucide": "^1.0.74",
    "@takram/three-atmosphere": "^0.19.1",
    "@takram/three-clouds": "^0.7.6",
    "@takram/three-geospatial-effects": "^0.6.4",
    "@zappar/msdf-generator": "^1.2.4"
  }
}
