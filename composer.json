{
    "name": "vrodos/vrodos-plugin",
    "description": "WordPress plugin for VRodos 3D content creation.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Anastasios Papazoglou Chalikias",
            "email": "tpapazoglou@iti.gr"
        }
    ],
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "rector/rector": "^1.2",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "rector": "rector process",
        "rector:dry": "rector process --dry-run",
        "cs": "phpcs --standard=WordPress .",
        "cs:fix": "phpcbf --standard=WordPress .",
        "test": "phpunit tests"
    }
}